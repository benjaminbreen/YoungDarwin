# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/multiplayer-worker/.wrangler/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
desktop.ini
*.download/
*.sb-*
* 2.js
* 2.jsx
/darwin_meshy.glb
*.pem

# local/raw 3D asset source dumps
# Runtime assets required by the game live in public/assets/models and are
# tracked intentionally as deployable files. Raw import/source material is
# kept local unless explicitly promoted with git add -f and a manifest note.
/assets-src/**
!/assets-src/
!/assets-src/.gitkeep
!/assets-src/raw/
!/assets-src/raw/.gitkeep
!/assets-src/processed/
!/assets-src/processed/.gitkeep
!/assets-src/references/
!/assets-src/references/.gitkeep

# public should contain runtime-ready assets only; ignore source/import leftovers
/public/assets/models/**/source/
/public/assets/models/**/*.zip
/public/assets/models/**/*.rar
/public/assets/models/**/*.fbx
/public/assets/models/**/*.FBX
/public/assets/models/**/*.obj
/public/assets/models/**/*.OBJ
/public/assets/models/animals/*.glb
/public/assets/models/animals/*/textures/
/public/assets/models/animals/alt iguana/
/public/assets/models/animals/iguana/
/public/assets/models/animals/hawk/
/public/assets/models/animals/lizard/
/public/assets/models/animals/red-tailed-hawk-in-flight/
/public/assets/models/animals/seal/
/public/assets/models/animals/snake/
/public/assets/models/livestock/
/public/assets/models/nature/*.glb
!/public/assets/models/nature/runtime-*.glb
!/public/assets/models/nature/Rock_Medium_*.glb
/public/assets/models/nature/*/source/
/public/assets/models/nature/*/textures/
/public/assets/models/nature/source/*

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# raw asset source dumps (root)
/Dense Bushland/
/desert plant pack.blend
/uploads-files-*.rar
/*.glb
/*.fbx
/*.FBX
/*.blend
/*.obj
/*.OBJ
