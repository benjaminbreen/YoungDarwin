  "inspectables": [
    {
      "id": "bedroom-washstand",
      "mode": "interior-message",
      "label": "washstand",
      "text": "Press E to look at the washstand",
      "message": "A ewer and basin, the water grey with limewash dust. The towel is damp; in this climate it never fully dries.",
      "position": [-1.6, 0.9, -0.72],
      "radius": 1.35
    },
    {
      "id": "store-door-closed",
      "mode": "interior-message",
      "label": "colony store door",
      "text": "Press E to try the colony store",
      "message": "The store is locked. Its barrels, tools, and ration books are held against the colony's account.",
      "position": [5.1, 1.1, 0.02],
      "radius": 1.45
    },
    {
      "id": "gillray-plumb-pudding",
      "mode": "interior-message",
      "label": "framed caricature",
      "text": "Press E to study the caricature",
      "message": "A hand-coloured Gillray: Pitt and Bonaparte carving the globe like a plum pudding. Thirty years old and browning at the edges, but Lawson evidently still finds it apt.",
      "position": [3.3, 1.6, 6.95],
      "radius": 1.35
    },
    {
      "id": "gillray-slippy-weather",
      "mode": "interior-message",
      "label": "framed caricature",
      "text": "Press E to study the caricature",
      "message": "Gillray's 'Very Slippy-Weather' — a gentleman flat on the ice outside Humphrey's print-shop, his barometer held safely aloft. An odd comfort in a settlement where it rains most days.",
      "position": [3.3, 1.6, 2.0],
      "radius": 1.35
    },
    {
      "id": "thornton-cereus",
      "mode": "interior-message",
      "label": "botanical print",
      "text": "Press E to study the botanical print",
      "message": "Thornton's night-blowing cereus, luminous against a moonlit ruin. A reminder that plates like these sell in London for more than a colonist earns in a season.",
      "position": [10.0, 1.6, 2.6],
      "radius": 1.35
    },
    {
      "id": "thornton-carnations",
      "mode": "interior-message",
      "label": "botanical print",
      "text": "Press E to study the botanical print",
      "message": "A group of striped carnations from Thornton's Temple of Flora — English garden flowers hung where no carnation will ever grow.",
      "position": [3.75, 1.6, 0.4],
      "radius": 1.35
    },
    {
      "id": "office-globe",
      "mode": "interior-message",
      "label": "table globe",
      "text": "Press E to examine the globe",
      "message": "A small table globe on a turned stand, its varnish crazed by the damp. The Galápagos are a scatter of unnamed specks a hand's width from Peru.",
